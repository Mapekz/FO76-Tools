# Run from esm/.  Mirrors the CI checks exactly.
# Install `just` once: cargo install just
#
# Usage:
#   just          -> fmt + clippy + test  (the full local CI pass)
#   just audit    -> schema parity gate (needs ../TES5Edit checkout/symlink)
#   just test-esm /path/a.esm /path/b.esm  -> env-gated diff integration test

default: check

# Run the full check suite (same as CI rust matrix).
check: fmt clippy test

# Verify formatting.
fmt:
    cargo fmt --check

# Lint with all features so the server bin is included.
clippy:
    cargo clippy --all-targets -- -D warnings
    cargo clippy --all-targets --features server -- -D warnings

# Run all tests (game-data tests are #[ignore]-gated).
test:
    cargo test

# Schema parity audit against the Pascal source in ../TES5Edit.
# Expects ../TES5Edit = Eckserah/TES5Edit @ 80a2c3c6 (branch dev-4.1.6).
#   git clone https://github.com/Eckserah/TES5Edit.git ../TES5Edit && git -C ../TES5Edit checkout 80a2c3c6
audit:
    python3 tools/extractor/audit.py --gate

# Diff two ESM versions (integration test normally skipped by #[ignore]).
test-esm a b:
    RUST_TEST_ESM_A={{a}} RUST_TEST_ESM_B={{b}} cargo test -- --ignored

# Generate patch notes from two ESM files.
# Produces patch_notes_<date>.md next to NEW and discord_chunks_<date>/ next to NEW.
# Assumes loose string files live in strings/ next to the ESMs (or pass STRINGS_DIR=…).
#
# Usage:
#   just patch-notes SeventySix_20260619.esm SeventySix_20260626.esm
#   STRINGS_DIR=strings just patch-notes old.esm new.esm
#   HIGHLIGHTS=highlights.md just patch-notes old.esm new.esm
patch-notes old new:
    python3 tools/make_patch_notes.py \
        "{{old}}" "{{new}}" \
        --strings-dir "${STRINGS_DIR:-strings}" \
        ${HIGHLIGHTS:+--highlights-file "$HIGHLIGHTS"} \
        ${LANG:+--lang "$LANG"} \
        ${OUT_DIR:+--out-dir "$OUT_DIR"}
