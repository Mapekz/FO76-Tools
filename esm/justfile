# Run from esm/.  Local check suite for the esm Rust crate; closely matches the CI
# rust job (fmt / clippy / test / generated-TypeScript drift guard) but is not
# identical — see below.
# Install `just` once: cargo install just
#
# CI also runs (not covered by `just check`):
#   - schema parity audit (`just audit`, separate recipe; needs ../TES5Edit)
#   - Python tooling tests (`just patch-tools-test`)
#   - esm-viewer typecheck + unit tests (cd ../esm-viewer && npm run typecheck && npm run test)
#   - napi native-addon build + smoke (continue-on-error in CI)
#
# Usage:
#   just          -> fmt + clippy + test + gen-types + drift check (full local esm pass)
#   just gen-types -> regenerate ../esm-viewer/src/shared/generated/ from Rust DTOs
#   just audit    -> schema parity gate (needs ../TES5Edit checkout/symlink)
#   just patch-tools-test -> Python tooling test suite (also enforced in CI)
#   just test-esm /path/a.esm /path/b.esm  -> env-gated diff integration test

default: check

# Full local esm check (matches the CI rust matrix for esm, including server-feature
# tests and the generated-types drift guard: `gen-types` must produce no diff).
check: fmt clippy test gen-types
    git diff --exit-code -- ../esm-viewer/src/shared/generated/

# Verify formatting.
fmt:
    cargo fmt --check

# Lint with all features so the server bin is included.
clippy:
    cargo clippy --all-targets -- -D warnings
    cargo clippy --all-targets --features server -- -D warnings

# Run all tests (game-data integration tests are env-gated and skip silently when unset).
test:
    cargo test
    cargo test --features server

# Regenerate the TypeScript mirrors of the N-API DTOs (ts-rs, see Cargo.toml
# dev-dependencies) plus their hand-written companions (esm/tests/gen_bindings.rs:
# recordTypeNames.generated.ts from schema/fo76.json, markers.generated.ts from
# src/decode.rs's `markers` module) into ../esm-viewer/src/shared/generated/.
# TS_RS_EXPORT_DIR/TS_RS_LARGE_INT are set globally in .cargo/config.toml (not
# just here) so a bare `cargo test` can never fall back to ts-rs's default
# `./bindings` dir, which would collide with the tracked `bindings/napi/` crate.
# --test-threads=1: some of these tests share a target directory (mkdir +
# sibling files) and ts-rs itself recommends serializing export tests.
gen-types:
    cargo test export_bindings -- --test-threads=1

# Schema parity audit against the Pascal source in ../TES5Edit.
# Expects ../TES5Edit = Eckserah/TES5Edit @ 80a2c3c6 (branch dev-4.1.6).
#   git clone https://github.com/Eckserah/TES5Edit.git ../TES5Edit && git -C ../TES5Edit checkout 80a2c3c6
audit:
    python3 tools/extractor/audit.py --gate

# Diff two ESM versions with real game data (requires two ESM paths).
# The test is env-gated and skips silently when RUST_TEST_ESM_A/B are unset.
test-esm a b:
    RUST_TEST_ESM_A={{a}} RUST_TEST_ESM_B={{b}} cargo test diff_two_esm_versions_glob -- --nocapture

# Run the Python patch-notes tooling test suite.
patch-tools-test:
    python3 -m unittest discover -s tools/tests

# Mechanical patch-notes stage: diff.json + comprehensive.{md,json} + bundles.json
# + lints.json + manifest.json into the output dir. The narrative stage (per-category
# notes + Discord chunks) is the /patch-notes Claude skill, which calls this recipe.
#
# Strings are auto-detected from <esm_parent>/strings/ for each ESM.
# If both ESMs share a parent directory, the shared strings/ there is tried first.
# Use STRINGS_DIR to pass an explicit shared path.
#
# Usage:
#   just patch-notes /path/to/v1/ /path/to/v2/
#   OUT_DIR=/path/to/out just patch-notes /path/to/old/ /path/to/new/
#
# Env vars (all optional):
#   STRINGS_DIR    Shared strings directory for both ESMs. If omitted, auto-detected
#                  from <esm_parent>/strings/ (or <esm_parent> itself).
#   STARTUP_BA2    Path to a Startup BA2 — enables curve-table detail and
#                  crafting-quantity evaluation. Mutually exclusive with CURVES_DIR.
#   CURVES_DIR     misc/ directory extracted from Startup BA2 — loose alternative to
#                  STARTUP_BA2. Auto-detected from <new_esm_parent>/misc/ if omitted.
#   ESM_LANG       Localization language code (default: en). Named ESM_LANG to
#                  avoid collision with the system $LANG locale variable.
#   OUT_DIR        Output directory (default: patch_<old>_to_<new>/ next to NEW).
patch-notes old new:
    python3 tools/make_patch_notes.py \
        "{{old}}" "{{new}}" \
        ${STRINGS_DIR:+--strings-dir "$STRINGS_DIR"} \
        ${STARTUP_BA2:+--startup-ba2 "$STARTUP_BA2"} \
        ${CURVES_DIR:+--curves-dir "$CURVES_DIR"} \
        ${ESM_LANG:+--lang "$ESM_LANG"} \
        ${OUT_DIR:+--out-dir "$OUT_DIR"}
