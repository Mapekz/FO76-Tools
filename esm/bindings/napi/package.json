{
  "name": "@fo76/esm-napi",
  "version": "0.1.0",
  "description": "Native N-API binding for the esm crate",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "node smoke.mjs"
  },
  "napi": {
    "name": "esm-napi",
    "triples": {
      "defaults": true,
      "additional": ["aarch64-unknown-linux-gnu", "aarch64-apple-darwin"]
    }
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.4"
  }
}
