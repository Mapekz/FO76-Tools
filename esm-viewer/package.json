{
  "name": "@fo76/esm-viewer",
  "version": "0.1.0",
  "description": "FO76 ESM Viewer — Fallout 76 ESM record browser",
  "productName": "FO76 ESM Viewer",
  "main": "out/main/index.js",
  "scripts": {
    "predev": "npm run build:addon",
    "dev": "electron-vite dev",
    "prebuild": "npm run build:addon",
    "build": "electron-vite build",
    "build:addon": "npm --prefix ../esm/bindings/napi run build",
    "preview": "electron-vite preview",
    "package:dir": "electron-builder --dir",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@fo76/esm-napi": "file:../esm/bindings/napi"
  },
  "devDependencies": {
    "@tanstack/react-virtual": "^3.14.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "electron": "^34",
    "electron-builder": "^25",
    "electron-vite": "^2",
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "zustand": "^5"
  },
  "allowScripts": {
    "electron@34.5.8": true,
    "esbuild@0.21.5": true
  }
}
