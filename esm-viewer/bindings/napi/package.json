{
  "name": "@fo76/esm-napi",
  "version": "0.1.0",
  "description": "Native napi-rs binding for fo76-esm-parser",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "napi": {
    "binaryName": "fo76-esm-napi",
    "targets": [
      "x86_64-unknown-linux-gnu"
    ]
  },
  "devDependencies": {
    "@napi-rs/cli": "^3"
  }
}
